Drop -Werror from cet_set_compiler_flags and guard the test subdir.

1. nurandom builds DIAGS CAUTIOUS + WERROR (inline); under GCC 14 / C++20 (our
   art-stack standard, vs upstream's C++17 default) stricter diagnostics become
   hard errors. CXXFLAGS can't demote cetmodules' add_compile_options(-Werror),
   so drop the WERROR keyword.
2. add_subdirectory(test): guard behind BUILD_TESTING so a -DBUILD_TESTING=OFF
   packaging configure does not descend into the test tree.
See conda/potential_improvements.md (#2).
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -20,7 +20,7 @@
 include(CetCMakeEnv)
 cet_cmake_env()

-cet_set_compiler_flags(DIAGS CAUTIOUS WERROR
+cet_set_compiler_flags(DIAGS CAUTIOUS
   NO_UNDEFINED
   EXTRA_FLAGS -pedantic
   $<$<COMPILE_LANGUAGE:CXX>:-Wno-unused-local-typedefs
@@ -41,7 +41,9 @@

 # source
 add_subdirectory (nurandom)
-add_subdirectory (test)
+if(BUILD_TESTING)
+  add_subdirectory (test)
+endif()

 # ups - table and config files
